-function onDropCard(e) {
+function onDropCard(e, targetEmpId) {
+  e.preventDefault();
   e.stopPropagation();
+  if (!dragEmpId || dragEmpId === targetEmpId) return;
+  
+  // Reorder employees in array
+  const dragIndex = data.employees.findIndex(e => e.id === dragEmpId);
+  const targetIndex = data.employees.findIndex(e => e.id === targetEmpId);
+  if (dragIndex === -1 || targetIndex === -1) return;
+  
+  // Only allow reordering within same team
+  const dragEmp = data.employees[dragIndex];
+  const targetEmp = data.employees[targetIndex];
+  if (dragEmp.teamId !== targetEmp.teamId) return;
+  
+  // Remove and reinsert at new position
+  const [removed] = data.employees.splice(dragIndex, 1);
+  const newTargetIndex = data.employees.findIndex(e => e.id === targetEmpId);
+  data.employees.splice(newTargetIndex, 0, removed);
+  
+  saveDataAndSync();
+  render();
+  toast(`Reordered ${removed.name}`, 'success');
 }
 
